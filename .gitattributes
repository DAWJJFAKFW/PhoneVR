# Normalize line endings
* text=auto

# Source files
*.swift text eol=lf
*.metal text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.proto text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.plist text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ipa binary
*.exe binary
*.dll binary
